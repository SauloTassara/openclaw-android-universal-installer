#!/usr/bin/env bash
set -u

BASE="$HOME/.openclaw-android"
LOG="$BASE/logs/openclaw-gateway.log"
mkdir -p "$BASE/logs"

if tmux has-session -t openclaw 2>/dev/null; then
  echo "Gateway appears running in tmux session: openclaw"
  exit 0
fi

if ! command -v openclaw >/dev/null 2>&1; then
  echo "ERROR: openclaw not found. Gateway cannot start." >&2
  exit 1
fi

if ! openclaw config validate; then
  cat <<'EOF' >&2
ERROR: OpenClaw config is invalid. Gateway not started.
Try:
  openclaw doctor --fix
  openclaw config validate
EOF
  exit 1
fi

tmux new-session -d -s openclaw "bash -lc 'source ~/.bashrc 2>/dev/null || true; source ~/.openclaw/android-provider.env 2>/dev/null || true; export NODE_OPTIONS=--dns-result-order=ipv4first; openclaw gateway >> \"$LOG\" 2>&1'"
echo "openclaw gateway started in tmux session: openclaw"
